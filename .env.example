# SkillHub Compose environment
# Copy to .env in the repository root for docker compose on the server.

PUBLIC_APP_PORT=8080
PUBLIC_APP_URL=https://skillhub.example.com
CLIENT_URLS=https://skillhub.example.com
GITHUB_CALLBACK_URL=https://skillhub.example.com/api/v1/auth/github/callback
COOKIE_SECURE=true

POSTGRES_DB=skillhub
POSTGRES_USER=skillhub_user
POSTGRES_PASSWORD=skillhub_password
DATABASE_URL=postgresql://skillhub_user:skillhub_password@postgres:5432/skillhub
