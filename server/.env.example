# SkillHub Server — Environment Variables
# Copy this file to .env and fill in with your actual values

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development
# Options: development, production, test

PORT=5000
# Server port (default: 5000)

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/skillhub
# Format: postgresql://username:password@host:port/database
# Example (Yandex Cloud): postgresql://user:password@c-xxx.rw.mdb.yandexcloud.net:6432/skillhub?sslmode=require

# ============================================
# GITHUB OAUTH (Passport.js)
# ============================================
GITHUB_CLIENT_ID=Ov23lisJERlKjswaJjwC
# Get from: https://github.com/settings/developers → OAuth Apps → Create New OAuth App

GITHUB_CLIENT_SECRET=8d259f9404e432fbf0e27dde61788533c7e21e38
# Keep this SECRET! Never commit to git.

GITHUB_CALLBACK_URL=http://localhost:5000/auth/github/callback
# Change to your production URL when deploying
# Example: https://api.skillhub.example.com/auth/github/callback

# ============================================
# YANDEX GPT API (AI Scoring)
# ============================================
YANDEXGPT_API_KEY=AQVNxzjFbwEj4YMT_-_XmlpUAwSNnYnnoGeKWY0b
# Get from: Yandex Cloud Console → API keys
# Used for AI skill scoring (0-100 rating)

YANDEXGPT_FOLDER_ID=b1gdoose5habmm2ishlb
# Yandex Cloud Folder ID for YandexGPT API calls

# ============================================
# JWT SECRET (Session/Token)
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Generate a strong random string for JWT signing

JWT_EXPIRES_IN=7d
# JWT token expiration time (default: 7 days)

# ============================================
# CLIENT URL (Frontend CORS)
# ============================================
CLIENT_URL=http://localhost:5173
# Change to your production frontend URL when deploying
# Example: https://skillhub.example.com
# Used for CORS policy and OAuth redirects

CLIENT_URLS=https://skillhub.example.com,https://www.skillhub.example.com
# Optional comma-separated allowlist for additional frontend origins
# Leave empty in local development

# ============================================
# GITHUB API (for profile import)
# ============================================
GITHUB_API_TOKEN=your_github_personal_access_token
# Optional: for server-side GitHub API calls
# Get from: https://github.com/settings/tokens → Generate new token (repo scope)
# Increases API rate limit from 60 to 5000 requests/hour

# ============================================
# LOGGING & DEBUG
# ============================================
DEBUG=skillhub:*
# Set to * for verbose logging, or specific namespace like skillhub:api

LOG_LEVEL=info
# Options: error, warn, info, debug

# ============================================
# RATE LIMITING (optional)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
# Time window for rate limiting (15 minutes in ms)

RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window per IP
